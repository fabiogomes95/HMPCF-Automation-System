# ==============================================================================
# SEGURANÇA E CREDENCIAIS (EXTREMAMENTE CRÍTICO)
# ==============================================================================
# Impede que senhas, tokens e a chave do Google Cloud subam para o GitHub
credentials.json
.env
*.pem
*.key

# ==============================================================================
# BANCO DE DADOS (DADOS LOCAIS DO HOSPITAL)
# ==============================================================================
# CRÍTICO: Nunca subir o banco local pois contém o histórico real dos pacientes
hospital.db
*.db
*.sqlite3

# ==============================================================================
# ARQUIVOS DE DADOS E RELATÓRIOS (PROTEÇÃO LGPD)
# ==============================================================================
# Impede o upload de lotes do BPA, planilhas da recepção e listas de erros
*.csv
*.xlsx
*.xls
*.txt
!requirements.txt   # Exceção: O requirements.txt DEVE subir para o GitHub
/automacao/*.txt
/bpa/*.txt
/bpa/LOG_*.txt
Relatorio_Producao_*.xlsx

# ==============================================================================
# BACKUPS, LOGS E DASHBOARDS GERADOS
# ==============================================================================
# Mantém o repositório leve ignorando gráficos e backups temporários
migracao_backup/
dados.py
*.log
dashboard_*.png

# ==============================================================================
# AMBIENTES VIRTUAIS E DEPENDÊNCIAS
# ==============================================================================
# Ignora as pastas pesadas de instalação do Python
venv/
.venv/
env/
lib/
bin/
Include/

# ==============================================================================
# CACHE E ARQUIVOS DO SISTEMA (LIXO ELETRÔNICO)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db